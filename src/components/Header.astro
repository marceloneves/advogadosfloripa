---
import { site, nav } from '../data/site';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" class="flex items-center gap-2">
			<span class="text-2xl">⚖️</span>
			<span class="text-lg font-bold tracking-tight text-slate-900">{site.name}</span>
		</a>

		<nav class="hidden items-center gap-8 md:flex">
			{
				nav.map((item) => (
					<a
						href={item.href}
						class:list={[
							'text-sm font-medium transition hover:text-amber-600',
							isActive(item.href) ? 'text-amber-600' : 'text-slate-600',
						]}
					>
						{item.label}
					</a>
				))
			}
			<a
				href="/contato"
				class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700"
			>
				Fale conosco
			</a>
		</nav>

		<button
			id="menu-btn"
			class="text-slate-700 md:hidden"
			aria-label="Abrir menu"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
		</button>
	</div>

	<nav id="mobile-menu" class="hidden border-t border-slate-200 bg-white px-6 py-4 md:hidden">
		{
			nav.map((item) => (
				<a href={item.href} class="block py-2 text-sm font-medium text-slate-700">
					{item.label}
				</a>
			))
		}
	</nav>
</header>

<script>
	const btn = document.getElementById('menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
