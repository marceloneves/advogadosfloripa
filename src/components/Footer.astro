---
import { site, nav } from '../data/site';
---

<footer class="border-t border-slate-800 bg-slate-900 text-slate-300">
	<div class="mx-auto grid max-w-6xl gap-8 px-6 py-12 md:grid-cols-3">
		<div>
			<div class="flex items-center gap-2">
				<span class="text-2xl">⚖️</span>
				<span class="text-lg font-bold text-white">{site.name}</span>
			</div>
			<p class="mt-3 text-sm text-slate-400">{site.tagline}</p>
			<p class="mt-1 text-xs text-slate-500">{site.oab}</p>
		</div>

		<div>
			<h3 class="text-sm font-semibold text-white">Navegação</h3>
			<ul class="mt-3 space-y-2 text-sm">
				{nav.map((item) => (
					<li><a href={item.href} class="transition hover:text-amber-400">{item.label}</a></li>
				))}
			</ul>
		</div>

		<div>
			<h3 class="text-sm font-semibold text-white">Contato</h3>
			<ul class="mt-3 space-y-2 text-sm text-slate-400">
				<li>{site.address}</li>
				<li><a href={`tel:${site.phone}`} class="hover:text-amber-400">{site.phone}</a></li>
				<li><a href={`mailto:${site.email}`} class="hover:text-amber-400">{site.email}</a></li>
			</ul>
		</div>
	</div>

	<div class="border-t border-slate-800 py-6 text-center text-xs text-slate-500">
		© {new Date().getFullYear()} {site.name}. Todos os direitos reservados.
	</div>
</footer>
