---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---

<Layout title="Contato — Advogados Floripa">
	<section class="bg-slate-900 text-white">
		<div class="mx-auto max-w-6xl px-6 py-20">
			<p class="text-sm font-semibold uppercase tracking-widest text-amber-400">Contato</p>
			<h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Fale Conosco</h1>
			<p class="mt-4 max-w-2xl text-lg text-slate-300">
				Agende uma consulta ou tire suas dúvidas. Respondemos o mais breve possível.
			</p>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-20">
		<div class="grid gap-12 md:grid-cols-2">
			<!-- Info -->
			<div>
				<h2 class="text-2xl font-semibold text-slate-900">Informações de contato</h2>
				<ul class="mt-8 space-y-6">
					<li class="flex items-start gap-4">
						<span class="text-2xl">📍</span>
						<div>
							<div class="font-medium text-slate-900">Endereço</div>
							<div class="text-slate-600">{site.address}</div>
						</div>
					</li>
					<li class="flex items-start gap-4">
						<span class="text-2xl">📞</span>
						<div>
							<div class="font-medium text-slate-900">Telefone</div>
							<a href={`tel:${site.phone}`} class="text-slate-600 hover:text-amber-600">{site.phone}</a>
						</div>
					</li>
					<li class="flex items-start gap-4">
						<span class="text-2xl">✉️</span>
						<div>
							<div class="font-medium text-slate-900">E-mail</div>
							<a href={`mailto:${site.email}`} class="text-slate-600 hover:text-amber-600">{site.email}</a>
						</div>
					</li>
					<li class="flex items-start gap-4">
						<span class="text-2xl">💬</span>
						<div>
							<div class="font-medium text-slate-900">WhatsApp</div>
							<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener" class="text-slate-600 hover:text-amber-600">
								Enviar mensagem
							</a>
						</div>
					</li>
				</ul>
			</div>

			<!-- Form -->
			<div class="rounded-2xl border border-slate-200 p-8">
				<h2 class="text-2xl font-semibold text-slate-900">Envie uma mensagem</h2>
				<form
					class="mt-6 space-y-4"
					action={`https://wa.me/${site.whatsapp}`}
					method="get"
					id="contact-form"
				>
					<div>
						<label for="nome" class="block text-sm font-medium text-slate-700">Nome</label>
						<input id="nome" name="nome" type="text" required
							class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-2.5 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500" />
					</div>
					<div>
						<label for="email" class="block text-sm font-medium text-slate-700">E-mail</label>
						<input id="email" name="email" type="email" required
							class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-2.5 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500" />
					</div>
					<div>
						<label for="mensagem" class="block text-sm font-medium text-slate-700">Mensagem</label>
						<textarea id="mensagem" name="mensagem" rows="4" required
							class="mt-1 w-full rounded-lg border border-slate-300 px-4 py-2.5 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500"></textarea>
					</div>
					<button type="submit"
						class="w-full rounded-lg bg-slate-900 px-6 py-3 font-semibold text-white transition hover:bg-slate-700">
						Enviar via WhatsApp
					</button>
				</form>
			</div>
		</div>
	</section>

	<script define:vars={{ whatsapp: site.whatsapp }}>
		const form = document.getElementById('contact-form');
		form?.addEventListener('submit', (e) => {
			e.preventDefault();
			const nome = form.nome.value;
			const email = form.email.value;
			const msg = form.mensagem.value;
			const text = `Olá! Meu nome é ${nome} (${email}). ${msg}`;
			window.open(`https://wa.me/${whatsapp}?text=${encodeURIComponent(text)}`, '_blank');
		});
	</script>
</Layout>
