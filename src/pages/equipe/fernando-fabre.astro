---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

const lawyer = {
  name: 'Fernando Luis Fabre',
  initials: 'FF',
  role: 'Advogado',
  city: 'Florianópolis/SC',
  status: 'Casado',
};

const areas = [
  'Direito Criminal',
  'Tribunal do Júri',
  'Direito Militar',
  'Direito Administrativo',
  'Defesa de Servidores Públicos',
  'Registro e Porte de Arma de Fogo',
];

const roles = [
  'Membro da Comissão de Direito Militar da OAB/SC',
  'Membro da Comissão de Direito do Servidor Público da OAB/SC',
];

const education = [
  { title: 'Bacharelado em Direito', org: 'Univali', period: '2008' },
  { title: 'Ciências Políticas', org: 'UNINTER', period: 'Cursando' },
  { title: 'Especialização em Ciências Penais', org: 'Universidade Anhanguera', period: '2010' },
  { title: 'Especialização em Direito Público', org: 'Universidade Anhanguera', period: '2012' },
  { title: 'Criminologia, Política Criminal e Segurança Pública', org: 'Universidade Anhanguera', period: '2014' },
  { title: 'Especialização em Direito Militar', org: 'Faculdade Legale', period: 'Cursando' },
];

const experience = [
  {
    title: 'Oficial (1º Tenente) da Força Aérea Brasileira',
    detail: 'Chefe da Assessoria Jurídica ao Comando da Base Aérea de Florianópolis, por 8 anos. Docente de Direito Penal e Processual Penal Militar, Organização Judiciária Militar e Sindicância em formação militar.',
  },
  {
    title: 'Residente Jurídico — Ministério Público de Santa Catarina',
    detail: 'Estágio de pós-graduação (MP-Residente) por 3 anos, com confecção de peças privativas de Promotor de Justiça e condução de procedimentos administrativos pré-judiciais.',
  },
  {
    title: 'Advogado — atuação de mais de 5 anos',
    detail: 'Exercício da advocacia com ênfase em Direito Criminal, Militar e Administrativo.',
  },
];
---

<Layout
	title={`${lawyer.name} — Advogado | Advogados Floripa`}
	description={`${lawyer.name}, advogado em Florianópolis. Especialista em Direito Criminal, Militar, Administrativo e Defesa de Servidores Públicos.`}
>
	<!-- Hero -->
	<section class="bg-slate-900 text-white">
		<div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-6 py-20 md:flex-row md:items-center">
			<div class="flex h-40 w-40 shrink-0 items-center justify-center rounded-full bg-slate-800 text-5xl font-bold text-amber-400 ring-4 ring-slate-700">
				{lawyer.initials}
			</div>
			<div class="text-center md:text-left">
				<p class="text-sm font-semibold uppercase tracking-widest text-amber-400">{lawyer.role}</p>
				<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">{lawyer.name}</h1>
				<p class="mt-3 max-w-xl text-lg font-medium text-slate-300">
					Especialista em Direito Criminal, Militar e Administrativo
				</p>
				<div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
					<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
						class="rounded-lg bg-amber-500 px-5 py-2.5 font-semibold text-slate-900 transition hover:bg-amber-400">
						Falar no WhatsApp
					</a>
					<a href="/contato" class="rounded-lg border border-slate-600 px-5 py-2.5 font-semibold text-white transition hover:border-slate-400">
						Agendar consulta
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Dados + Áreas -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="grid gap-12 md:grid-cols-3">
			<div class="md:col-span-1">
				<h2 class="text-lg font-semibold text-slate-900">Dados profissionais</h2>
				<dl class="mt-4 space-y-3 text-sm">
					<div>
						<dt class="text-slate-500">Naturalidade</dt>
						<dd class="font-medium text-slate-900">{lawyer.city}</dd>
					</div>
					<div>
						<dt class="text-slate-500">Estado civil</dt>
						<dd class="font-medium text-slate-900">{lawyer.status}</dd>
					</div>
				</dl>

				<h2 class="mt-8 text-lg font-semibold text-slate-900">Atuação institucional</h2>
				<ul class="mt-4 space-y-2 text-sm text-slate-700">
					{roles.map((r) => (
						<li class="flex gap-2"><span class="text-amber-500">▪</span>{r}</li>
					))}
				</ul>
			</div>

			<div class="md:col-span-2">
				<h2 class="text-lg font-semibold text-slate-900">Áreas de atuação</h2>
				<div class="mt-4 flex flex-wrap gap-3">
					{areas.map((a) => (
						<span class="rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800">
							{a}
						</span>
					))}
				</div>

				<h2 class="mt-10 text-lg font-semibold text-slate-900">Sobre</h2>
				<p class="mt-4 leading-relaxed text-slate-700">
					Fernando Luis Fabre é advogado com sólida trajetória no Direito Criminal,
					Militar e Administrativo. Atuou por oito anos como Oficial (1º Tenente) da
					Força Aérea Brasileira, chefiando a Assessoria Jurídica ao Comando da Base
					Aérea de Florianópolis, e por três anos como Residente Jurídico junto ao
					Ministério Público de Santa Catarina. Especialista em Tribunal do Júri,
					crimes financeiros, questões de vencimentos e pensões militares, defesa de
					servidores públicos e obtenção de registro e porte de arma de fogo. É membro
					das Comissões de Direito Militar e de Direito do Servidor Público da OAB/SC.
				</p>
			</div>
		</div>
	</section>

	<!-- Experiência -->
	<section class="bg-slate-50">
		<div class="mx-auto max-w-4xl px-6 py-16">
			<h2 class="text-2xl font-bold tracking-tight text-slate-900">Experiência Profissional</h2>
			<div class="mt-8 space-y-6">
				{experience.map((e) => (
					<div class="rounded-2xl bg-white p-6 shadow-sm">
						<h3 class="font-semibold text-slate-900">{e.title}</h3>
						<p class="mt-2 text-sm leading-relaxed text-slate-600">{e.detail}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Formação -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<h2 class="text-2xl font-bold tracking-tight text-slate-900">Formação Acadêmica</h2>
		<div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			{education.map((e) => (
				<div class="rounded-2xl border border-slate-200 p-6">
					<div class="text-sm font-semibold text-amber-600">{e.period}</div>
					<h3 class="mt-2 font-semibold text-slate-900">{e.title}</h3>
					<p class="mt-1 text-sm text-slate-600">{e.org}</p>
				</div>
			))}
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-16 text-center text-white">
			<h2 class="text-3xl font-bold">Precisa de defesa criminal ou militar?</h2>
			<p class="mx-auto mt-3 max-w-xl text-slate-300">
				Fale diretamente com o advogado Fernando Luis Fabre e receba uma avaliação do seu caso.
			</p>
			<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
				class="mt-8 inline-block rounded-lg bg-amber-500 px-8 py-3 font-semibold text-slate-900 transition hover:bg-amber-400">
				Falar com Fernando Fabre
			</a>
		</div>
	</section>
</Layout>
