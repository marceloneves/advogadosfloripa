---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

const lawyer = {
  name: 'Matheus Stein',
  initials: 'MS',
  role: 'Advogado',
  oab: 'OAB/SC 78.639',
  birth: '28 de novembro de 1995',
  city: 'Santo Amaro da Imperatriz/SC',
  status: 'Casado',
};

const areas = [
  'Direito Previdenciário',
  'Direito Processual Civil',
  'Direito Civil',
];

const education = [
  {
    title: 'Bacharelado em Direito',
    org: 'Universidade do Sul de Santa Catarina (Unisul)',
    period: '2016 — Fevereiro/2020',
  },
  {
    title: 'Pós-graduação em Direito Processual Civil',
    org: 'Especialização',
    period: 'Concluída',
  },
  {
    title: 'Pós-graduação em Direito Previdenciário',
    org: 'Especialização',
    period: 'Em andamento',
  },
];

const timeline = [
  {
    year: '2016',
    text: 'Ingresso no curso de Direito pela Unisul, incentivado pela vivência no serviço militar.',
  },
  {
    year: '2017 — 2020',
    text: 'Atuação na Assessoria Jurídica da Base Aérea (Força Aérea Brasileira) como assistente jurídico, prestando apoio a oficiais em demandas jurídicas do setor.',
  },
  {
    year: 'Fevereiro/2020',
    text: 'Conclusão da graduação em Direito e encerramento de seis anos de serviço no quartel.',
  },
  {
    year: '2025',
    text: 'Retomada dos estudos jurídicos com foco na aprovação na Ordem dos Advogados do Brasil.',
  },
  {
    year: '2026',
    text: 'Aprovação e inscrição na OAB/SC, retornando à advocacia e integrando o escritório Advogados Floripa.',
  },
];
---

<Layout
	title={`${lawyer.name} — Advogado | Advogados Floripa`}
	description={`${lawyer.name}, ${lawyer.oab}. Advogado em Florianópolis com atuação em Direito Previdenciário, Processual Civil e Civil.`}
>
	<!-- Hero -->
	<section class="bg-slate-900 text-white">
		<div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-6 py-20 md:flex-row md:items-center">
			<div class="flex h-40 w-40 shrink-0 items-center justify-center rounded-full bg-slate-800 text-5xl font-bold text-amber-400 ring-4 ring-slate-700">
				{lawyer.initials}
			</div>
			<div class="text-center md:text-left">
				<p class="text-sm font-semibold uppercase tracking-widest text-amber-400">{lawyer.role}</p>
				<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">{lawyer.name}</h1>
				<p class="mt-3 text-lg font-medium text-slate-300">{lawyer.oab}</p>
				<div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
					<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
						class="rounded-lg bg-amber-500 px-5 py-2.5 font-semibold text-slate-900 transition hover:bg-amber-400">
						Falar no WhatsApp
					</a>
					<a href="/contato" class="rounded-lg border border-slate-600 px-5 py-2.5 font-semibold text-white transition hover:border-slate-400">
						Agendar consulta
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Dados + Áreas -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="grid gap-12 md:grid-cols-3">
			<div class="md:col-span-1">
				<h2 class="text-lg font-semibold text-slate-900">Dados profissionais</h2>
				<dl class="mt-4 space-y-3 text-sm">
					<div>
						<dt class="text-slate-500">Inscrição</dt>
						<dd class="font-medium text-slate-900">{lawyer.oab}</dd>
					</div>
					<div>
						<dt class="text-slate-500">Naturalidade</dt>
						<dd class="font-medium text-slate-900">{lawyer.city}</dd>
					</div>
					<div>
						<dt class="text-slate-500">Nascimento</dt>
						<dd class="font-medium text-slate-900">{lawyer.birth}</dd>
					</div>
					<div>
						<dt class="text-slate-500">Estado civil</dt>
						<dd class="font-medium text-slate-900">{lawyer.status}</dd>
					</div>
				</dl>
			</div>

			<div class="md:col-span-2">
				<h2 class="text-lg font-semibold text-slate-900">Áreas de atuação</h2>
				<div class="mt-4 flex flex-wrap gap-3">
					{areas.map((a) => (
						<span class="rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800">
							{a}
						</span>
					))}
				</div>

				<h2 class="mt-10 text-lg font-semibold text-slate-900">Sobre</h2>
				<p class="mt-4 leading-relaxed text-slate-700">
					Matheus Stein é advogado inscrito na {lawyer.oab}, com formação em Direito
					pela Unisul e especialização em Direito Processual Civil. Iniciou sua
					trajetória jurídica ainda na graduação, atuando por mais de dois anos na
					Assessoria Jurídica da Base Aérea, onde desenvolveu prática no apoio a
					demandas do setor público militar. Atualmente cursa pós-graduação em
					Direito Previdenciário e integra o escritório Advogados Floripa,
					dedicando-se ao atendimento próximo e técnico de seus clientes.
				</p>
			</div>
		</div>
	</section>

	<!-- Formação -->
	<section class="bg-slate-50">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold tracking-tight text-slate-900">Formação Acadêmica</h2>
			<div class="mt-8 grid gap-6 md:grid-cols-3">
				{education.map((e) => (
					<div class="rounded-2xl bg-white p-6 shadow-sm">
						<div class="text-sm font-semibold text-amber-600">{e.period}</div>
						<h3 class="mt-2 font-semibold text-slate-900">{e.title}</h3>
						<p class="mt-1 text-sm text-slate-600">{e.org}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Trajetória -->
	<section class="mx-auto max-w-3xl px-6 py-16">
		<h2 class="text-2xl font-bold tracking-tight text-slate-900">Trajetória</h2>
		<ol class="mt-8 space-y-8 border-l-2 border-slate-200 pl-8">
			{timeline.map((t) => (
				<li class="relative">
					<span class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-amber-500 ring-4 ring-white"></span>
					<div class="text-sm font-semibold text-amber-600">{t.year}</div>
					<p class="mt-1 text-slate-700">{t.text}</p>
				</li>
			))}
		</ol>
	</section>

	<!-- CTA -->
	<section class="bg-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-16 text-center text-white">
			<h2 class="text-3xl font-bold">Precisa de orientação jurídica?</h2>
			<p class="mx-auto mt-3 max-w-xl text-slate-300">
				Fale diretamente com o advogado Matheus Stein e receba uma avaliação do seu caso.
			</p>
			<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
				class="mt-8 inline-block rounded-lg bg-amber-500 px-8 py-3 font-semibold text-slate-900 transition hover:bg-amber-400">
				Falar com Matheus Stein
			</a>
		</div>
	</section>
</Layout>
