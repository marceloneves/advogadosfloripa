---
import Layout from '../../layouts/Layout.astro';
import { site } from '../../data/site';

const lawyer = {
  name: 'Asterley Kincezski da Silva',
  initials: 'AK',
  role: 'Advogado',
  oab: 'OAB/SC 18.119',
};

const areas = [
  'Direito da Saúde',
  'Direito Público',
  'Judicialização da Saúde',
  'Direito Administrativo',
  'Administração Pública',
  'Assessoria Jurídica Institucional',
];

const roles = [
  'Advocacia privada — escritório Kincezski e Fabre Advocacia',
  'Gerente de Processos Institucionais da Diretoria do Plano de Saúde do Servidor (SC Saúde)',
  'Membro da Comissão de Direito da Saúde da OAB/SC',
];

const education = [
  { title: 'Bacharelado em Direito', org: 'Universidade do Vale do Itajaí (Univali)', period: 'Julho/2002' },
  { title: 'Pós-graduação lato sensu', org: 'Instituto de Estudos Luiz Flávio Gomes (IELF)', period: '2004' },
];

const experience = [
  { period: '2024 — atual', text: 'Gerente de Processos Institucionais da Diretoria do Plano de Saúde do Servidor do Estado de Santa Catarina (SC Saúde).' },
  { period: '2023', text: 'Assessor Jurídico do Plano de Saúde dos Servidores do Estado de Santa Catarina (SC Saúde).' },
  { period: '2017 — 2021', text: 'Servidor Público Estadual lotado na Secretaria do Processo Judicial (SEPROJ), da Procuradoria-Geral do Estado de Santa Catarina (PGE/SC).' },
  { period: '2012 — 2014', text: 'Assessoria Jurídica do DETRAN/SC, tendo assumido interinamente a função de Assessor Jurídico.' },
  { period: '2006 — 2008', text: 'Consultor Jurídico da Secretaria Municipal de Saúde de Florianópolis e advogado da AFLOV.' },
  { period: '2005 — 2008', text: 'Sócio da sociedade Capella-Kincezski Advocacia e Consultoria Jurídica.' },
];

const highlights = [
  'Representante da OAB/SC no Conselho Nacional de Justiça — comissão especial de judicialização de medicamentos (2009)',
  'Ex-Vice-Presidente da Comissão de Direito à Saúde Pública da OAB/SC',
  'Ex-Conselheiro do Conselho Estadual e Municipal de Saúde',
  'Conciliador do Juizado Especial Cível da Capital',
];
---

<Layout
	title={`${lawyer.name} — Advogado | Advogados Floripa`}
	description={`${lawyer.name}, ${lawyer.oab}. Advogado em Florianópolis especialista em Direito da Saúde, Direito Público e judicialização da saúde.`}
>
	<!-- Hero -->
	<section class="bg-slate-900 text-white">
		<div class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-6 py-20 md:flex-row md:items-center">
			<div class="flex h-40 w-40 shrink-0 items-center justify-center rounded-full bg-slate-800 text-5xl font-bold text-amber-400 ring-4 ring-slate-700">
				{lawyer.initials}
			</div>
			<div class="text-center md:text-left">
				<p class="text-sm font-semibold uppercase tracking-widest text-amber-400">{lawyer.role}</p>
				<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">{lawyer.name}</h1>
				<p class="mt-3 text-lg font-medium text-slate-300">{lawyer.oab}</p>
				<p class="mt-1 max-w-xl text-slate-400">Especialista em Direito da Saúde e Direito Público</p>
				<div class="mt-6 flex flex-wrap justify-center gap-3 md:justify-start">
					<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
						class="rounded-lg bg-amber-500 px-5 py-2.5 font-semibold text-slate-900 transition hover:bg-amber-400">
						Falar no WhatsApp
					</a>
					<a href="/contato" class="rounded-lg border border-slate-600 px-5 py-2.5 font-semibold text-white transition hover:border-slate-400">
						Agendar consulta
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Dados + Áreas -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="grid gap-12 md:grid-cols-3">
			<div class="md:col-span-1">
				<h2 class="text-lg font-semibold text-slate-900">Atuação atual</h2>
				<ul class="mt-4 space-y-3 text-sm text-slate-700">
					{roles.map((r) => (
						<li class="flex gap-2"><span class="text-amber-500">▪</span>{r}</li>
					))}
				</ul>
			</div>

			<div class="md:col-span-2">
				<h2 class="text-lg font-semibold text-slate-900">Áreas de atuação</h2>
				<div class="mt-4 flex flex-wrap gap-3">
					{areas.map((a) => (
						<span class="rounded-full border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800">
							{a}
						</span>
					))}
				</div>

				<h2 class="mt-10 text-lg font-semibold text-slate-900">Sobre</h2>
				<p class="mt-4 leading-relaxed text-slate-700">
					Asterley Kincezski da Silva é advogado inscrito na {lawyer.oab}, com mais de
					duas décadas de trajetória no Direito Público e no Direito da Saúde. Servidor
					da Secretaria de Estado da Administração de Santa Catarina, atua como Gerente
					de Processos Institucionais da Diretoria do Plano de Saúde do Servidor (SC
					Saúde) e é membro da Comissão de Direito da Saúde da OAB/SC. Reúne ampla
					experiência em saúde pública, administração pública, judicialização da saúde
					e assessoria jurídica institucional.
				</p>
			</div>
		</div>
	</section>

	<!-- Experiência -->
	<section class="bg-slate-50">
		<div class="mx-auto max-w-4xl px-6 py-16">
			<h2 class="text-2xl font-bold tracking-tight text-slate-900">Experiência Profissional</h2>
			<ol class="mt-8 space-y-8 border-l-2 border-slate-200 pl-8">
				{experience.map((e) => (
					<li class="relative">
						<span class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-amber-500 ring-4 ring-slate-50"></span>
						<div class="text-sm font-semibold text-amber-600">{e.period}</div>
						<p class="mt-1 text-slate-700">{e.text}</p>
					</li>
				))}
			</ol>
		</div>
	</section>

	<!-- Formação + Destaques -->
	<section class="mx-auto max-w-6xl px-6 py-16">
		<div class="grid gap-12 md:grid-cols-2">
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-slate-900">Formação Acadêmica</h2>
				<div class="mt-6 space-y-4">
					{education.map((e) => (
						<div class="rounded-2xl border border-slate-200 p-6">
							<div class="text-sm font-semibold text-amber-600">{e.period}</div>
							<h3 class="mt-2 font-semibold text-slate-900">{e.title}</h3>
							<p class="mt-1 text-sm text-slate-600">{e.org}</p>
						</div>
					))}
				</div>
			</div>
			<div>
				<h2 class="text-2xl font-bold tracking-tight text-slate-900">Atuação Institucional</h2>
				<ul class="mt-6 space-y-3 text-slate-700">
					{highlights.map((h) => (
						<li class="flex gap-3"><span class="mt-1 text-amber-500">▪</span><span>{h}</span></li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-16 text-center text-white">
			<h2 class="text-3xl font-bold">Questões de saúde ou direito público?</h2>
			<p class="mx-auto mt-3 max-w-xl text-slate-300">
				Fale diretamente com o advogado Asterley Kincezski e receba uma avaliação do seu caso.
			</p>
			<a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener"
				class="mt-8 inline-block rounded-lg bg-amber-500 px-8 py-3 font-semibold text-slate-900 transition hover:bg-amber-400">
				Falar com Asterley Kincezski
			</a>
		</div>
	</section>
</Layout>
